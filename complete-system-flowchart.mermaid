flowchart TD
    Start([System Start / بدء النظام]) --> UserRegister[User registers: email + password<br/>المستخدم يسجل: البريد الإلكتروني + كلمة المرور]
    
    UserRegister --> CheckFirstTime{First time user?<br/>مستخدم لأول مرة؟}
    
    CheckFirstTime -->|No / لا| Login[User logs in<br/>المستخدم يسجل الدخول]
    Login --> RequestRecs[User requests recommendations<br/>المستخدم يطلب التوصيات]
    
    CheckFirstTime -->|Yes / نعم| ShowForm[Show preference form<br/>عرض نموذج التفضيلات]
    
    ShowForm --> FormInput[Form contains:<br/>النموذج يحتوي على:]
    
    subgraph FormInput["Preference Form / نموذج التفضيلات"]
        Questions[Questions to answer<br/>أسئلة للإجابة]
        ImageSelect[Images to multi-select as favorable<br/>صور للاختيار المتعدد كتفضيلات]
    end
    
    FormInput --> Questions
    FormInput --> ImageSelect
    
    Questions --> SubmitForm[User submits form<br/>المستخدم يرسل النموذج]
    ImageSelect --> SubmitForm
    
    SubmitForm --> ProcessInputs[Process User Inputs<br/>معالجة مدخلات المستخدم]
    
    subgraph ProcessInputs["Input Processing / معالجة المدخلات"]
        ProcessTextual[Process Textual Answers<br/>معالجة الإجابات النصية]
        ProcessVisual[Process Visual Image Selections<br/>معالجة اختيارات الصور المرئية]
    end
    
    ProcessInputs --> ProcessTextual
    ProcessInputs --> ProcessVisual
    
    ProcessTextual --> ImageProcessing[Image Processing Service<br/>خدمة معالجة الصور]
    
    subgraph ImageProcessing["Image Processing / معالجة الصور"]
        Preprocess[Preprocessing: resize + normalize<br/>معالجة أولية: تغيير الحجم + تطبيع]
        FeatureExtract[Feature extraction: CNN / CLIP<br/>استخراج الخصائص: CNN / CLIP]
        GenerateEmbedding[Generate 512-dim Embedding Vector<br/>توليد متجه تضمين 512 بعد]
    end
    
    ImageProcessing --> Preprocess
    Preprocess --> FeatureExtract
    FeatureExtract --> GenerateEmbedding
    
    ProcessVisual --> ImageProcessing
    
    GenerateEmbedding --> CheckEmbedding{Embedding created?<br/>تم توليد التضمين؟}
    
    CheckEmbedding -->|No / لا| ErrorExtraction[Return error: Feature extraction failed<br/>إرجاع خطأ: فشل استخراج الخصائص]
    ErrorExtraction --> End2([End / نهاية])
    
    CheckEmbedding -->|Yes / نعم| BuildProfile[Build User Preference Profile<br/>بناء ملف تفضيلات المستخدم]
    
    BuildProfile --> CombineInputs[Combine Textual + Visual Data<br/>دمج البيانات النصية والمرئية]
    CombineInputs --> LearnPreferences[Learn User Preferences<br/>تعلم تفضيلات المستخدم]
    LearnPreferences --> SaveUserPref[Save to UserPreference table<br/>حفظ في جدول تفضيلات المستخدم]
    SaveUserPref --> PrefSaved([User Preference Saved<br/>تم حفظ تفضيلات المستخدم])
    
    PrefSaved --> RequestRecs
    
    RequestRecs --> MatchingEngine[Matching Engine<br/>محرك المطابقة]
    
    subgraph MatchingEngine["Matching Engine / محرك المطابقة"]
        GetUserPref[Get User Preference Vector<br/>الحصول على متجه تفضيلات المستخدم]
        GetDestinations[(Query Destinations Database<br/>استعلام قاعدة بيانات الوجهات)]
        CosineSimilarity[Calculate Cosine Similarity<br/>حساب التشابه باستخدام جيب التمام]
        RankResults[Rank Destinations by Similarity<br/>ترتيب الوجهات حسب التشابه]
    end
    
    MatchingEngine --> GetUserPref
    GetUserPref --> CosineSimilarity
    GetDestinations --> CosineSimilarity
    CosineSimilarity --> RankResults
    
    RankResults --> CheckResults{Results found?<br/>هل توجد نتائج؟}
    
    CheckResults -->|Yes / نعم| GenerateRecs[Generate Recommendations List<br/>إنشاء قائمة التوصيات]
    CheckResults -->|No / لا| Fallback[Fallback: Popular Destinations<br/>إرجاع الأكثر شعبية]
    
    GenerateRecs --> ReturnJSON[Return Recommendations JSON<br/>JSON إرجاع الاستجابة]
    Fallback --> ReturnJSON
    
    ReturnJSON --> DisplayResults[Display Results to User<br/>عرض النتائج للمستخدم]
    DisplayResults --> End3([End / نهاية])
    
    style Start fill:#90EE90
    style End1 fill:#FFB6C1
    style End2 fill:#FFB6C1
    style End3 fill:#90EE90
    style PrefSaved fill:#87CEEB
    style ValidateImage fill:#FFE4B5
    style CheckEmbedding fill:#FFE4B5
    style CheckResults fill:#FFE4B5
    style ImageProcessing fill:#E6E6FA
    style MatchingEngine fill:#E6E6FA
    style GetDestinations fill:#DDA0DD
    style ErrorInvalid fill:#FFB6C1
    style ErrorExtraction fill:#FFB6C1
    style Fallback fill:#FFE4B5
    style GenerateRecs fill:#90EE90


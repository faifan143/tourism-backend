erDiagram
    USER {
        string id PK
        string email UK
        string password
        string role
        datetime createdAt
        datetime updatedAt
    }

    USER_PREFERENCE {
        string id PK
        string userId FK
        bytes vector
    }

    COUNTRY {
        string id PK
        string name UK
        string description
        string imageUrl
        datetime createdAt
        datetime updatedAt
    }

    CITY {
        string id PK
        string name UK
        string description
        string imageUrl
        string countryId FK
        datetime createdAt
        datetime updatedAt
    }

    PLACE {
        string id PK
        string name UK
        string description
        string location
        string[] imageUrls
        string cityId FK
        int popularity
        datetime createdAt
        datetime updatedAt
    }

    CATEGORY {
        string id PK
        string name UK
    }

    THEME {
        string id PK
        string name UK
    }

    ACTIVITY {
        string id PK
        string name UK
        string description
        string imageUrl
        string placeId FK
        datetime createdAt
        datetime updatedAt
    }

    PLACE_CATEGORY {
        string placeId PK,FK
        string categoryId PK,FK
    }

    PLACE_THEME {
        string placeId PK,FK
        string themeId PK,FK
    }

    TRIP_ACTIVITY {
        string tripId PK,FK
        string activityId PK,FK
    }

    HOTEL {
        string id PK
        string name UK
        string description
        string imageUrl
        string cityId FK
        float pricePerNight
        datetime createdAt
        datetime updatedAt
    }

    ROOMTYPE {
        string id PK
        string hotelId FK
        string name
        string description
        int maxGuests
        float pricePerNight
        int capacity
        datetime createdAt
        datetime updatedAt
    }

    ROOM {
        string id PK
        string hotelId FK
        string roomTypeId FK
        string roomNumber
        string status
        datetime createdAt
        datetime updatedAt
    }

    RESERVATION {
        string id PK
        string userId FK
        string roomId FK
        string roomTypeId FK
        datetime startDate
        datetime endDate
        int guests
        float totalPrice
        string status
        datetime createdAt
        datetime updatedAt
    }

    TRIP {
        string id PK
        string name
        string description
        string imageUrl
        string cityId FK
        string hotelId FK
        float price
        datetime createdAt
        datetime updatedAt
    }

    TRIPRESERVATION {
        string id PK
        string userId FK
        string tripId FK
        int guests
        string status
        datetime createdAt
        datetime updatedAt
    }

    %% Relationships
    USER ||--o| USER_PREFERENCE : "has"
    USER ||--o{ RESERVATION : "makes"
    USER ||--o{ TRIPRESERVATION : "makes"

    COUNTRY ||--o{ CITY : "has"

    CITY ||--o{ PLACE : "has"
    CITY ||--o{ HOTEL : "has"
    CITY ||--o{ TRIP : "has"

    PLACE ||--o{ PLACE_CATEGORY : "has"
    PLACE ||--o{ PLACE_THEME : "has"
    PLACE ||--o{ ACTIVITY : "offers"

    CATEGORY ||--o{ PLACE_CATEGORY : "belongs_to"
    THEME ||--o{ PLACE_THEME : "belongs_to"

    PLACE_CATEGORY }o--|| PLACE : "references"
    PLACE_CATEGORY }o--|| CATEGORY : "references"

    PLACE_THEME }o--|| PLACE : "references"
    PLACE_THEME }o--|| THEME : "references"

    ACTIVITY ||--o{ TRIP_ACTIVITY : "included_in"
    TRIP ||--o{ TRIP_ACTIVITY : "includes"

    TRIP_ACTIVITY }o--|| TRIP : "references"
    TRIP_ACTIVITY }o--|| ACTIVITY : "references"

    HOTEL ||--o{ ROOMTYPE : "has"
    HOTEL ||--o{ ROOM : "has"
    HOTEL ||--o{ TRIP : "optional_hotel"

    ROOMTYPE ||--o{ ROOM : "has"
    ROOMTYPE ||--o{ RESERVATION : "booked_in"

    ROOM ||--o{ RESERVATION : "booked_in"

    TRIP ||--o{ TRIPRESERVATION : "booked_in"

